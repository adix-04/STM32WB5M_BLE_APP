/*-----------------------------------------------------------------------------
//Purpose   : Update memory Reading completed
//Inputs    : None
//Outputs   : None
//Return    : None
//Notes     : None
-----------------------------------------------------------------------------*/
void UpadteMemoryReadCompletedStatus()
{
    SSD1306_GotoXY (1,1);
    SSD1306_Puts (MEMORY_READ_COMPLTD, &Font_7x10, 1);
    SSD1306_GotoXY (1, 20);
    SSD1306_Puts (DAQ_COMPLETED2, &Font_7x10, 1);
    SSD1306_GotoXY (1, 30);
